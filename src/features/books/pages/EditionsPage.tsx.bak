import { useState } from 'react';
import { useParams, Link, useSearchParams } from 'react-router-dom';
import { useQuery, useQueryClient } from '@tanstack/react-query';
import { getWorkEditionsFilteredAPI, getWorkAPI, createReviewAPI } from '@/services/api/booksApi';
import { Edition } from '@estante/common-types';
import { PATHS } from '@/router/paths';
import { LoadingSpinner } from '@/components/ui/loading-spinner';
import { ShelfButton } from '@/features/books/components/ShelfButton';
import { StarRating } from '@/features/books/components/StarRating';
import { getLanguageName, getLanguageFlag } from '@/data/book-languages';
import { getFormatById } from '@/data/book-formats';
import { formatPublicationDate } from '@/lib/utils';
import { PageMetadata } from '@/components/seo/PageMetadata';
import { Button } from '@/components/ui/button';
import { Filter, ChevronRight, Home, Book, Layers, ChevronDown, ChevronUp } from 'lucide-react';
import { motion, AnimatePresence } from 'framer-motion';
import { itemVariants, SMOOTH_TRANSITION } from '@/lib/animations';
import { useAuth } from '@/hooks/useAuth';
import { toastSuccessClickable, toastErrorClickable } from '@/components/ui/toast';
import {
    Select,
    SelectContent,
    SelectItem,
    SelectTrigger,
    SelectValue,
} from '@/components/ui/select';
import {
    Breadcrumb,
    BreadcrumbLink,
    BreadcrumbList,
    BreadcrumbPage,
} from '@/components/ui/breadcrumb';

interface Filters {
    language: string;
    formatId: string;
    page: number;
}

export function EditionsPage() {
    const { workId } = useParams<{ workId: string }>();
    const [searchParams] = useSearchParams();
    const queryClient = useQueryClient();
    const { user } = useAuth();
    const fromEditionId = searchParams.get('from');
    
    const [filters, setFilters] = useState<Filters>({ language: '', formatId: '', page: 1 });
    const [showFilters, setShowFilters] = useState(false);
    const [expandedItems, setExpandedItems] = useState<Set<string>>(new Set());

    const { data: work } = useQuery({
        queryKey: ['work', workId],
        queryFn: () => getWorkAPI(workId!),
        enabled: !!workId,
    });

    const { data: editions, isLoading } = useQuery({
        queryKey: ['editions', workId, filters],
        queryFn: () => getWorkEditionsFilteredAPI(workId!, {
            language: filters.language || undefined,
            formatId: filters.formatId || undefined,
            page: filters.page,
            limit: 10,
        }),
        enabled: !!workId,
    });

    const availableLanguages = editions?.data
        ? Array.from(new Set(editions.data.map(e => e.language))).filter(Boolean)
        : [];

    const availableFormats = editions?.data
        ? Array.from(new Set(editions.data.map(e => e.formatId))).filter(Boolean)
        : [];

    const setFilter = (key: keyof Omit<Filters, 'page'>, value: string) => {
        setFilters(f => ({ ...f, [key]: value, page: 1 }));
    };
    const clearFilters = () => setFilters({ language: '', formatId: '', page: 1 });
    const hasFilters = filters.language || filters.formatId;

    const toggleExpand = (id: string) => {
        setExpandedItems(prev => {
            const next = new Set(prev);
            if (next.has(id)) next.delete(id);
            else next.add(id);
            return next;
        });
    };

    const toggleAll = (expand: boolean) => {
        if (expand && editions?.data) {
            setExpandedItems(new Set(editions.data.map(e => e.id)));
        } else {
            setExpandedItems(new Set());
        }
    };

    const handleRate = async (editionId: string, rating: number) => {
        if (!user) {
            toastErrorClickable('Faça login para avaliar uma edição.');
            return;
        }
        try {
            await createReviewAPI({
                editionId,
                workId: workId!,
                rating,
                content: '',
                containsSpoiler: false
            });
            queryClient.invalidateQueries({ queryKey: ['editions'] });
            toastSuccessClickable('Avaliação registrada!');
        } catch (err) {
            toastErrorClickable('Erro ao avaliar. Tente na página do livro.');
        }
    };

    const allExpanded = editions?.data && editions.data.length > 0 && expandedItems.size === editions.data.length;

    return (
        <>
            <PageMetadata
                title={`Todas as edições — ${work?.title || 'Livro'} | Estante de Bolso`}
                description={`Lista completa de edições cadastradas para ${work?.title || 'esta obra'}.`}
            />
            <div className="max-w-7xl mx-auto px-4">
                <Breadcrumb className="hidden md:flex mt-4 mb-2">
                    <BreadcrumbList>
                        <AnimatePresence initial={false}>
                            <motion.li
                                variants={itemVariants}
                                initial="hidden"
                                animate="visible"
                                className="inline-flex items-center gap-1.5"
                                transition={SMOOTH_TRANSITION}
                            >
                                <BreadcrumbLink asChild>
                                    <Link to={PATHS.HOME} aria-label="Página Inicial" className="p-2 rounded-md hover:bg-gray-100 transition-colors">
                                        <Home className="h-4 w-4 text-gray-500" />
                                    </Link>
                                </BreadcrumbLink>
                            </motion.li>

                            <motion.li variants={itemVariants} transition={SMOOTH_TRANSITION} className="inline-flex items-center text-gray-300">
                                <ChevronRight className="h-3.5 w-3.5" />
                            </motion.li>

                            <motion.li
                                variants={itemVariants}
                                transition={{ ...SMOOTH_TRANSITION, delay: 0.08 }}
                                className="inline-flex items-center gap-1.5"
                            >
                                <BreadcrumbLink asChild>
                                    <Link
                                        to={fromEditionId ? PATHS.BOOK({ editionId: fromEditionId }) : PATHS.WORK({ workId: work?.id || '' })}
                                        className="flex items-center gap-2 px-2 py-1 rounded-md hover:bg-gray-100 transition-colors text-sm font-medium text-gray-500"
                                    >
                                        < Book className="h-4 w-4" />
                                        {work?.title || 'Livro'}
                                    </Link>
                                </BreadcrumbLink>
                            </motion.li>

                            <motion.li variants={itemVariants} transition={{ ...SMOOTH_TRANSITION, delay: 0.16 }} className="inline-flex items-center text-gray-300">
                                <ChevronRight className="h-3.5 w-3.5" />
                            </motion.li>

                            <motion.li
                                variants={itemVariants}
                                transition={{ ...SMOOTH_TRANSITION, delay: 0.24 }}
                                className="inline-flex items-center gap-1.5"
                            >
                                <BreadcrumbPage className="flex items-center gap-2 px-2 py-1 text-sm font-medium text-foreground">
                                    <Layers className="h-4 w-4" />
                                    Edições
                                </BreadcrumbPage>
                            </motion.li>
                        </AnimatePresence>
                    </BreadcrumbList>
                </Breadcrumb>
            </div>

            <main className="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-2 pb-8 animate-in fade-in duration-500">
                <div className="mb-8 border-b border-gray-100 pb-6 mt-1.5">
                    <h1 className="text-3xl font-bold text-gray-900 mb-2 leading-tight">
                        Edições de {work?.title}
                    </h1>

                    <div className="flex flex-col sm:flex-row sm:items-baseline gap-x-4 gap-y-1 text-[15px] text-gray-600">
                        {work?.primaryAuthors && (
                            <p>
                                por {work.primaryAuthors.map((author, idx) => (
                                    <span key={author.id}>
                                        <Link to={PATHS.AUTHOR({ personId: author.id })} className="text-emerald-600 font-medium hover:underline transition-colors">
                                            {author.name}
                                        </Link>
                                        {idx < work.primaryAuthors.length - 1 && ', '}
                                    </span>
                                ))}
                            </p>
                        )}
                        {work?.originalPublicationDate && (
                            <p className="border-l border-gray-300 sm:pl-4">
                                Primeira publicação em {new Date(work.originalPublicationDate).toLocaleDateString('pt-BR', { month: 'long', day: 'numeric', year: 'numeric' })}
                            </p>
                        )}
                    </div>
                </div>

                <div className="flex items-center justify-between mb-6">
                    <div className="flex items-center gap-4">
                        <h2 className="text-[13px] font-bold uppercase tracking-wider text-gray-400">
                            Mostrando {editions?.pagination.total || 0} edições
                        </h2>
                        <div className="h-4 w-px bg-gray-200" />
                        <button 
                            onClick={() => toggleAll(!allExpanded)}
                            className="text-[11px] font-bold text-indigo-600 hover:text-indigo-800 transition-colors uppercase tracking-widest"
                        >
                            {allExpanded ? 'Colapsar tudo' : 'Expandir tudo'}
                        </button>
                    </div>
                    <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => setShowFilters(!showFilters)}
                        className={`text-[12px] font-bold uppercase tracking-widest ${hasFilters ? 'text-indigo-600' : 'text-gray-500'}`}
                    >
                        <Filter className="w-3.5 h-3.5 mr-2" />
                        Filtros {hasFilters ? '(ativos)' : ''}
                    </Button>
                </div>

                {showFilters && (
                    <div className="bg-gray-50 rounded-lg p-4 mb-8 grid grid-cols-1 sm:grid-cols-3 gap-6 border border-gray-100 animate-in slide-in-from-top-2 duration-300">
                        <div>
                            <label className="text-[11px] font-bold uppercase text-gray-400 mb-1.5 block tracking-widest leading-none">Idioma</label>
                            <Select value={filters.language || 'all'} onValueChange={(val: string) => setFilter('language', val === 'all' ? '' : val)}>
                                <SelectTrigger className="w-full bg-white h-9 border-gray-200 text-[13px] font-medium">
                                    <SelectValue placeholder="Todos os idiomas" />
                                </SelectTrigger>
                                <SelectContent className="bg-white border-gray-200 shadow-md">
                                    <SelectItem value="all" className="text-[13px]">Todos os idiomas</SelectItem>
                                    {availableLanguages.map(langCode => (
                                        <SelectItem key={langCode} value={langCode} className="text-[13px]">
                                            {getLanguageFlag(langCode)} {getLanguageName(langCode)}
                                        </SelectItem>
                                    ))}
                                </SelectContent>
                            </Select>
                        </div>
                        <div>
                            <label className="text-[11px] font-bold uppercase text-gray-400 mb-1.5 block tracking-widest leading-none">Formato</label>
                            <Select value={filters.formatId || 'all'} onValueChange={(val: string) => setFilter('formatId', val === 'all' ? '' : val)}>
                                <SelectTrigger className="w-full bg-white h-9 border-gray-200 text-[13px] font-medium">
                                    <SelectValue placeholder="Todos os formatos" />
                                </SelectTrigger>
                                <SelectContent className="bg-white border-gray-200 shadow-md">
                                    <SelectItem value="all" className="text-[13px]">Todos os formatos</SelectItem>
                                    {availableFormats.map(fmtId => (
                                        <SelectItem key={fmtId} value={fmtId} className="text-[13px]">
                                            {getFormatById(fmtId)?.name || 'Outro'}
                                        </SelectItem>
                                    ))}
                                </SelectContent>
                            </Select>
                        </div>
                        <div className="flex items-end pb-1.5">
                            {hasFilters && (
                                <button onClick={clearFilters} className="text-[10px] text-red-500 font-bold uppercase tracking-widest transition-colors">
                                    Limpar Filtros
                                </button>
                            )}
                        </div>
                    </div>
                )}

                {isLoading ? (
                    <div className="flex justify-center items-center py-20">
                        <LoadingSpinner size="lg" className="text-indigo-600" />
                    </div>
                ) : editions && editions.data.length > 0 ? (
                    <div className="divide-y divide-gray-100 border-t border-gray-100">
                        {editions.data.map((edition: Edition) => {
                            const isExpanded = expandedItems.has(edition.id);
                            return (
                                <div key={edition.id} className="py-6 flex gap-6 group">
                                    <Link to={PATHS.BOOK({ editionId: edition.id })} className="shrink-0">
                                        <div className="w-[80px] h-[120px] rounded-sm overflow-hidden bg-gray-50 border border-gray-200 shadow-sm group-hover:shadow-md transition-shadow">
                                            {edition.coverUrl ? (
                                                <img src={edition.coverUrl} alt={edition.title} className="w-full h-full object-cover" />
                                            ) : (
                                                <div className="w-full h-full bg-gray-100 flex items-center justify-center text-gray-300" />
                                            )}
                                        </div>
                                    </Link>

                                    <div className="flex-1 min-w-0">
                                        <div className="flex items-start justify-between gap-4">
                                            <Link to={PATHS.BOOK({ editionId: edition.id })} className="text-[16px] font-bold text-gray-900 hover:text-indigo-700 block mb-0.5 transition-colors">
                                                {edition.title} ({getFormatById(edition.formatId!)?.name || 'Vários'})
                                            </Link>
                                            <button 
                                                onClick={() => toggleExpand(edition.id)}
                                                className="shrink-0 flex items-center gap-1 text-[11px] font-bold text-indigo-600 hover:text-indigo-800 uppercase tracking-widest transition-colors"
                                            >
                                                {isExpanded ? (
                                                    <><ChevronUp className="w-3.5 h-3.5" /> menos detalhes</>
                                                ) : (
                                                    <><ChevronDown className="w-3.5 h-3.5" /> mais detalhes</>
                                                )}
                                            </button>
                                        </div>

                                        <div className="space-y-0.5 text-[13px] text-gray-600 mt-0.5">
                                            <p>
                                                Publicado em {edition.publicationDate ? formatPublicationDate(edition.publicationDate) : 'Data desconhecida'}
                                                {edition.publisher?.name && ` por ${edition.publisher.name}`}
                                            </p>
                                            
                                            <AnimatePresence>
                                                {isExpanded && (
                                                    <motion.div 
                                                        initial={{ height: 0, opacity: 0 }}
                                                        animate={{ height: 'auto', opacity: 1 }}
                                                        exit={{ height: 0, opacity: 0 }}
                                                        className="overflow-hidden mt-3 pt-3 border-t border-gray-50"
                                                    >
                                                        <div className="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-2 text-[12px]">
                                                            {edition.subtitle && (
                                                                <p className="col-span-full italic text-gray-500 mb-1">{edition.subtitle}</p>
                                                            )}
                                                            <div className="flex justify-between border-b border-gray-50/50 pb-1">
                                                                <span className="text-gray-400">Páginas</span>
                                                                <span className="font-medium">{edition.pages || '---'}</span>
                                                            </div>
                                                            <div className="flex justify-between border-b border-gray-50/50 pb-1">
                                                                <span className="text-gray-400">ISBN13</span>
                                                                <span className="font-medium font-mono">{edition.isbn13 || '---'}</span>
                                                            </div>
                                                            {edition.isbn10 && (
                                                                <div className="flex justify-between border-b border-gray-50/50 pb-1">
                                                                    <span className="text-gray-400">ISBN10</span>
                                                                    <span className="font-medium font-mono">{edition.isbn10}</span>
                                                                </div>
                                                            )}
                                                            {edition.dimensions && (
                                                                <div className="flex justify-between border-b border-gray-50/50 pb-1">
                                                                    <span className="text-gray-400">Dimensões</span>
                                                                    <span className="font-medium">
                                                                        {[edition.dimensions.width, edition.dimensions.height, edition.dimensions.thickness].filter(Boolean).join(' × ')} cm
                                                                    </span>
                                                                </div>
                                                            )}
                                                            <div className="flex justify-between border-b border-gray-50/50 pb-1">
                                                                <span className="text-gray-400">Idioma</span>
                                                                <span className="font-medium flex items-center gap-1.5">
                                                                    {getLanguageFlag(edition.language)} {getLanguageName(edition.language)}
                                                                </span>
                                                            </div>
                                                        </div>
                                                        {edition.description && (
                                                            <div className="mt-3 text-gray-600 leading-relaxed text-[12px]">
                                                                <p className="font-bold text-gray-400 uppercase text-[9px] tracking-widest mb-1">Resumo da Edição</p>
                                                                {edition.description}
                                                            </div>
                                                        )}
                                                    </motion.div>
                                                )}
                                            </AnimatePresence>
                                        </div>
                                    </div>

                                    <div className="shrink-0 w-[175px] flex flex-col items-center gap-2">
                                        <ShelfButton 
                                            editionId={edition.id} 
                                            workId={work?.id || edition.workId} 
                                            size="sm"
                                        />
                                        
                                        <div className="flex flex-col items-center gap-1">
                                            <StarRating 
                                                rating={edition.stats?.averageRating || 0} 
                                                size="xs" 
                                                interactive={true}
                                                onRate={(rating) => handleRate(edition.id, rating)}
                                            />
                                            <span className="text-[11px] text-gray-500 font-medium">Avaliar este livro</span>
                                        </div>
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                ) : (
                    <div className="text-center py-24 bg-gray-50 rounded-xl border border-dashed border-gray-200">
                        <h3 className="text-gray-800 font-semibold text-lg">Nenhuma edição encontrada</h3>
                        <p className="text-gray-500 text-sm mt-1">Tente remover os filtros ou aguarde novas edições.</p>
                    </div>
                )}

                {editions && editions.pagination.totalPages > 1 && (
                    <div className="flex items-center justify-center gap-4 mt-12 py-6 border-t border-gray-100">
                        <Button
                            variant="ghost"
                            size="sm"
                            disabled={filters.page === 1}
                            onClick={() => setFilters((f: Filters) => ({ ...f, page: f.page - 1 }))}
                            className="text-[12px] font-bold uppercase tracking-widest disabled:opacity-30"
                        >
                            « anterior
                        </Button>

                        <div className="flex items-center gap-2">
                            {Array.from({ length: editions.pagination.totalPages }).map((_, i) => (
                                <button
                                    key={i + 1}
                                    onClick={() => setFilters((f: Filters) => ({ ...f, page: i + 1 }))}
                                    className={`w-8 h-8 rounded-full text-[13px] font-bold transition-all ${filters.page === i + 1
                                            ? 'bg-indigo-600 text-white shadow-md'
                                            : 'text-gray-400 hover:bg-gray-100'
                                        }`}
                                >
                                    {i + 1}
                                </button>
                            ))}
                        </div>

                        <Button
                            variant="ghost"
                            size="sm"
                            disabled={filters.page === editions.pagination.totalPages}
                            onClick={() => setFilters((f: Filters) => ({ ...f, page: f.page + 1 }))}
                            className="text-[12px] font-bold uppercase tracking-widest disabled:opacity-30"
                        >
                            próxima »
                        </Button>
                    </div>
                )}
            </main>
        </>
    );
}
